# ============================================================
# CLAW BOT — Konfiguracja środowiska
# Skopiuj do .env i wypełnij wartości
# ============================================================

# --- Gateway ---
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=18789

# --- Telegram ---
# Pobierz od @BotFather na Telegram
TELEGRAM_BOT_TOKEN=

# --- Discord ---
# Pobierz z https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Bezpieczeństwo ---
# ID użytkowników z dostępem (comma-separated)
# Telegram: użyj /start i sprawdź logi po uruchomieniu
# Discord: włącz Developer Mode i skopiuj User ID
TELEGRAM_WHITELIST=
DISCORD_WHITELIST=

# Opcjonalnie: hasło do WebChat
WEBCHAT_SECRET=

# --- Syntezator Mowy (TTS) ---
# Backend: piper | espeak | elevenlabs | disabled
TTS_BACKEND=piper

# Piper TTS (DOMYSLNY — najlepsza jakosc, lokalny, darmowy)
# Instalacja: https://github.com/rhasspy/piper/releases
# 1. Pobierz piper.exe (lub ./piper na Linux)
# 2. Pobierz model: pl_PL-gosia-medium.onnx (lub inny polski)
# 3. Ustawienia poniżej
TTS_PIPER_BINARY=piper
TTS_PIPER_MODEL=./models/pl_PL-gosia-medium.onnx

# Fallback: espeak-ng (słabsza jakość, ale działa od razu)
# TTS_BACKEND=espeak
# TTS_ESPEAK_LANG=pl
# TTS_ESPEAK_VOICE=pl+m3

# ElevenLabs (wymaga API key, https://elevenlabs.io)
# TTS_BACKEND=elevenlabs
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# --- Logowanie ---
LOG_LEVEL=info
LOG_DIR=./logs

# --- Tryb ---
NODE_ENV=development
